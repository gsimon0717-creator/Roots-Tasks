# Roots-Tasks environment variables.
# Copy to .env for local development. In production these are set as Cloud Run
# env vars / secrets.

# DATABASE_URL: PostgreSQL connection string (required).
#   Local dev:   postgresql://USER:PASSWORD@localhost:5432/roots_tasks
#   Cloud Run:   postgresql://USER:PASSWORD@/roots_tasks?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL="postgresql://postgres:password@localhost:5432/roots_tasks"

# GOOGLE_OAUTH_CLIENT_ID: OAuth 2.0 Web Client ID, required to enable real
# Google SSO. If unset, /api/auth/google-sso returns 501 by design.
GOOGLE_OAUTH_CLIENT_ID=""

# --- In-app AI agent (2026-07-16) ---
# ANTHROPIC_API_KEY: Anthropic API key that powers the in-UI task assistant.
# Server-only — never exposed to the browser. If unset, POST /api/agent/chat
# returns 501 and the agent panel is disabled; the rest of the app is unaffected.
ANTHROPIC_API_KEY=""

# ANTHROPIC_MODEL: which Claude model the agent uses. Defaults to claude-sonnet-5
# if unset; override to pin a specific model string.
ANTHROPIC_MODEL="claude-sonnet-5"

# AGENT_NAME: display name for the assistant in the UI. Defaults to "Ivy".
AGENT_NAME="Ivy"
